<quick-add-dialog id="quick-add-dialog">
  <dialog
    class="quick-add-modal quick-add-drawer dialog-modal dialog-drawer color-{{ settings.popover_color_scheme }}"
    ref="dialog"
    scroll-lock
  >
    <button
      ref="closeButton"
      on:click="/closeDialog"
      class="button button-unstyled close-button quick-add-modal__close quick-add-drawer__close"
      aria-label="{{ 'accessibility.close_dialog' | t }}"
    >
      {{- 'icon-close.svg' | inline_asset_content -}}
    </button>
    <div
      id="quick-add-modal-content"
      class="quick-add-modal__content quick-add-drawer__content"
    ></div>
  </dialog>
</quick-add-dialog>

{% stylesheet %}
  /* ---------------------------------------------------------------------------
     Quick Add — Side Drawer
     Variante atelier: pannello a scomparsa da destra, layout verticale
     compatto con immagine in alto e variant picker / ATC sotto.
     --------------------------------------------------------------------------- */

  .quick-add-drawer {
    --quick-add-drawer-width: clamp(360px, 32vw, 480px);

    position: fixed;
    padding: 0;
    margin: 0 0 0 auto;
    border: none;
    border-left: var(--style-border-drawer);
    box-shadow: var(--shadow-drawer, 0 5px 30px rgb(0 0 0 / 0.18));
    border-radius: 0;
    width: var(--quick-add-drawer-width);
    max-width: 95vw;
    height: 100dvh;
    max-height: 100dvh;
    min-height: unset;
    overflow: hidden;
    background-color: var(--color-background);
  }

  .quick-add-drawer:modal {
    max-height: 100dvh;
  }

  @media screen and (max-width: 749px) {
    .quick-add-drawer {
      --quick-add-drawer-width: 100vw;
      max-width: 100vw;
      border-left: none;
    }
  }

  .quick-add-drawer__close {
    position: absolute;
    top: var(--margin-md);
    right: var(--margin-md);
    transition: transform 0.15s var(--animation-timing-bounce);
    z-index: var(--layer-raised);
  }

  .quick-add-drawer__close:active {
    transform: scale(0.85);
  }

  /* Reset del grid 7-col del modale: in drawer è uno stack verticale */
  .quick-add-drawer__content {
    display: flex;
    flex-direction: column;
    grid-template-columns: none;
    grid-template-rows: none;
    max-width: unset;
    height: 100%;
    overflow-y: auto;
    padding: 0;
    gap: 0;
  }

  /* Immagine prodotto — compatta in alto, ratio quadrato */
  .quick-add-drawer__content .product-information__media {
    position: relative;
    width: 100%;
    grid-column: unset;
    grid-row: unset;
    top: unset;
    overflow: hidden;
    aspect-ratio: 1;
    flex: 0 0 auto;
    animation: fadeIn 0.4s var(--animation-timing-fade-in) both;

    @media screen and (min-width: 750px) {
      position: relative;
      grid-column: unset;
      aspect-ratio: 4 / 5;
      max-height: 45dvh;
    }
  }

  .quick-add-drawer__content .product-information__media media-gallery,
  .quick-add-drawer__content .product-information__media slideshow-container,
  .quick-add-drawer__content .product-information__media slideshow-slides {
    position: relative;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .quick-add-drawer__content .product-information__media slideshow-slides {
    display: flex;
    flex-direction: row;
    gap: 0;
    overflow: hidden;
  }

  .quick-add-drawer__content .product-information__media slideshow-slide {
    width: 100%;
    flex: none;
    position: relative;
    transform: none;
    opacity: 1;
    visibility: visible;
  }

  /* Mostriamo solo la prima slide nel drawer per non distrarre */
  .quick-add-drawer__content .product-information__media slideshow-slide:not(:first-of-type) {
    display: none;
  }

  .quick-add-drawer__content .product-information__media .product-media,
  .quick-add-drawer__content .product-information__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Layout mobile (la JS rimuove .product-details e crea .product-header):
     applichiamo padding e flex anche a header + variant-picker + form direct children */
  .quick-add-drawer__content > .product-header,
  .quick-add-drawer__content > variant-picker,
  .quick-add-drawer__content > product-form-component {
    padding-inline: var(--padding-xl);
    width: 100%;
    box-sizing: border-box;
  }

  .quick-add-drawer__content > .product-header {
    display: flex;
    flex-direction: column;
    gap: var(--gap-2xs);
    padding-top: var(--padding-xl);
    padding-right: calc(var(--padding-xl) + var(--minimum-touch-target));
  }

  .quick-add-drawer__content > .product-header a {
    color: inherit;
    text-decoration: none;
    font-size: var(--font-size--lg);
    font-weight: 500;
    line-height: 1.25;
    width: fit-content;
  }

  .quick-add-drawer__content > .product-header a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .quick-add-drawer__content > variant-picker {
    padding-top: var(--padding-md);
  }

  .quick-add-drawer__content > product-form-component {
    padding-top: var(--padding-md);
    padding-bottom: var(--padding-2xl);
    margin-top: auto;
  }

  /* Dettagli prodotto — sotto l'immagine, scroll interno */
  .quick-add-drawer__content .product-details {
    grid-column: unset;
    grid-row: unset;
    display: flex;
    flex-direction: column;
    height: auto;
    max-height: none;
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    padding: var(--padding-xl) var(--padding-xl) var(--padding-2xl);

    dialog[open] & {
      animation: fadeSlideIn 0.35s var(--animation-timing-fade-in) both;
      animation-delay: 0.08s;
    }
  }

  /* Group block (contenitore del form interno) — niente padding aggiuntivo,
     la spaziatura la gestisce .product-details */
  .quick-add-drawer__content .product-details > .group-block {
    padding: 0;
    max-height: none;
  }

  .quick-add-drawer__content .group-block-content {
    gap: var(--gap-lg);
  }

  /* Titolo prodotto: cliccabile, stile atelier (serif coerente con il tema) */
  .quick-add-drawer__content .view-product-title {
    display: flex;
    padding: 0;
    margin-bottom: var(--margin-xs);
  }

  .quick-add-drawer__content .view-product-title a {
    color: inherit;
    text-decoration: none;
    text-align: left;
    font-size: var(--font-size--xl);
    font-weight: 500;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s var(--animation-easing);
    padding-right: calc(var(--minimum-touch-target) + var(--padding-sm));
  }

  .quick-add-drawer__content .view-product-title a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Override del nascondi-tutto del modale: nel drawer mostriamo gli stessi
     elementi sia su mobile che su desktop (titolo, prezzo, picker, buy buttons,
     inventario, view-more-details). Annulliamo la regola del modale. */
  .quick-add-drawer__content
    .product-details
    *:not(
      .group-block,
      .group-block-content,
      .buy-buttons-block,
      .buy-buttons-block *,
      .view-product-title,
      .view-product-title *,
      variant-picker,
      variant-picker *,
      product-price,
      product-price *,
      product-inventory,
      product-inventory *,
      .view-more-details__wrapper,
      .view-more-details__wrapper *
    ) {
    @media screen and (min-width: 750px) {
      /* stylelint-disable-next-line declaration-no-important */
      display: revert !important;
    }
  }

  /* Però manteniamo nascosti i blocchi descrizione / RTE lunghi: nel drawer
     vogliamo solo l'essenziale per l'acquisto */
  .quick-add-drawer__content .text-block.rte:not(product-price),
  .quick-add-drawer__content .group-block:has(> .group-block-content > rich-text-component) {
    display: none;
  }

  /* Variant picker — più aria, swatches ben distanziati */
  .quick-add-drawer__content variant-picker {
    flex: 0 0 auto;
    overflow-y: visible;
    padding-block-end: 0;
  }

  .quick-add-drawer__content .variant-picker__form {
    display: block;
  }

  .quick-add-drawer__content .variant-option + .variant-option {
    margin-top: var(--padding-md);
  }

  .quick-add-drawer__content .variant-option--swatches {
    padding-inline-start: 0;
  }

  .quick-add-drawer__content .variant-option--swatches legend {
    margin-inline-start: 0;
  }

  /* Pulsante "Vedi dettagli prodotto" in fondo */
  .quick-add-drawer__content .view-more-details__wrapper {
    display: flex;
    justify-content: flex-start;
    width: 100%;
    margin-top: var(--margin-sm);
  }

  .quick-add-drawer__content .view-more-details {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    font-size: var(--font-size--xs);
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.75;
  }

  .quick-add-drawer__content .view-more-details:hover {
    opacity: 1;
  }

  /* Bordi: nel drawer non vogliamo radius extra sull'immagine */
  .quick-add-drawer__content :is(
    .media-gallery--grid:not(.media-gallery--two-column) .product-media > *,
    .media-gallery--grid.media-gallery--two-column:not(.media-gallery--large-first-image)
    .product-media-container:nth-of-type(odd) .product-media > *,
    .media-gallery--grid.media-gallery--two-column.media-gallery--large-first-image
      .product-media-container:is(:first-of-type, :nth-of-type(even)) .product-media > *,
    .media-gallery--carousel slideshow-container
  ) {
    border-radius: 0;
  }

  .quick-add-drawer__content .media-gallery {
    padding: 0;
  }

  .quick-add-drawer__content slideshow-arrows,
  .quick-add-drawer__content slideshow-controls {
    display: none;
  }

  /* Backdrop più discreto rispetto al modale centrale */
  .quick-add-drawer::backdrop {
    background: rgb(var(--backdrop-color-rgb) / calc(var(--backdrop-opacity) * 0.6));
  }

  /* Animazioni — override delle animazioni del modale (slide top→bottom)
     per usare quelle del drawer (slide right→left).
     .dialog-drawer è già definita in base.css con slideInLeft/slideOutLeft. */
  .quick-add-drawer[open] {
    animation: slideInLeft var(--animation-speed) var(--animation-easing) forwards;
  }

  .quick-add-drawer.dialog-closing {
    animation: slideOutLeft var(--animation-speed) var(--animation-easing) forwards;
  }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
{% endstylesheet %}
