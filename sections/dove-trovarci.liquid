{%- liquid
  assign s = section.settings
  assign eyebrow = s.eyebrow
  assign heading = s.heading | default: 'Vieni a trovarci a Napoli.'
-%}

<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&display=swap">

<section
  id="DoveTrovarci-{{ section.id }}"
  class="dt color-{{ s.color_scheme }}"
  data-dt-root
  style="--dt-bg: {{ s.bg_color.red }} {{ s.bg_color.green }} {{ s.bg_color.blue }}; --dt-fg: {{ s.fg_color.red }} {{ s.fg_color.green }} {{ s.fg_color.blue }}; --dt-gold: {{ s.gold_color.red }} {{ s.gold_color.green }} {{ s.gold_color.blue }};"
>
  <div class="dt__wrap">
    <header class="dt__head">
      <div class="dt__head-main">
        {%- if eyebrow != blank -%}<p class="dt__eyebrow" data-dt-reveal>{{ eyebrow }}</p>{%- endif -%}
        {%- if heading != blank -%}<h2 class="dt__h2" data-dt-reveal>{{ heading }}</h2>{%- endif -%}
      </div>
      {%- if s.intro != blank -%}<p class="dt__intro" data-dt-reveal>{{ s.intro }}</p>{%- endif -%}
    </header>

    <span class="dt__stitch" aria-hidden="true" data-dt-reveal>
      <svg viewBox="0 0 1000 2" preserveAspectRatio="none"><line x1="0" y1="1" x2="1000" y2="1" stroke="currentColor" stroke-width="1.4" stroke-dasharray="7 5" vector-effect="non-scaling-stroke"/></svg>
    </span>

    <ul class="dt__grid" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign b = block.settings
          assign maps_url = b.maps_url
          if maps_url == blank and b.address != blank
            assign q = b.name | append: ' ' | append: b.address | url_encode
            assign maps_url = 'https://www.google.com/maps/search/?api=1&query=' | append: q
          endif
        -%}
        <li class="dt__card" data-dt-reveal {{ block.shopify_attributes }}>
          {%- if b.brand != blank -%}<p class="dt__card-brand">{{ b.brand }}</p>{%- endif -%}
          {%- if b.tag != blank -%}<span class="dt__card-tag">{{ b.tag }}</span>{%- endif -%}
          <h3 class="dt__card-name">{{ b.name | default: 'Punto vendita' }}</h3>

          {%- if b.address != blank -%}
            <p class="dt__card-line dt__card-address">{{ b.address | newline_to_br }}</p>
          {%- endif -%}

          {%- if b.phone != blank -%}
            <p class="dt__card-line">
              <a class="dt__card-phone" href="tel:{{ b.phone | remove: ' ' }}">{{ b.phone }}</a>
            </p>
          {%- endif -%}

          {%- if b.hours != blank -%}
            <p class="dt__card-line dt__card-hours">{{ b.hours }}</p>
          {%- endif -%}

          {%- if maps_url != blank -%}
            <a class="dt__card-cta" href="{{ maps_url }}" target="_blank" rel="noopener" aria-label="Indicazioni per {{ b.name | escape }}">
              <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-6-5.3-6-10a6 6 0 1 1 12 0c0 4.7-6 10-6 10Z"/><circle cx="12" cy="11" r="2.2"/></svg>
              <span>Indicazioni</span>
            </a>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% stylesheet %}
  .dt {
    --dt-bg-rgb: var(--dt-bg, 244 239 230);
    --dt-fg-rgb: var(--dt-fg, 14 14 12);
    --dt-gold-rgb: var(--dt-gold, 201 162 75);
    background: rgb(var(--dt-bg-rgb));
    color: rgb(var(--dt-fg-rgb));
    padding-block: clamp(64px, 10vw, 128px);
  }

  .dt__wrap {
    width: min(1240px, 100% - clamp(32px, 8vw, 120px));
    margin-inline: auto;
  }

  .dt__head {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
    gap: clamp(24px, 5vw, 80px);
    align-items: end;
  }

  .dt__head-main {
    min-width: 0;
  }

  .dt__head-main .dt__h2 {
    max-width: 14ch; /* ~2 righe: "Vieni a trovarci / a Napoli." */
  }

  .dt__eyebrow {
    margin: 0 0 0.9rem;
    font-family: var(--font-body--family, system-ui);
    font-size: 0.72rem;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: rgb(var(--dt-gold-rgb));
  }

  .dt__h2 {
    margin: 0;
    font-family: 'Fraunces', var(--font-heading--family, serif);
    font-weight: 300;
    font-variation-settings: 'opsz' 144;
    font-size: clamp(2rem, 4.6vw, 3.4rem);
    line-height: 1.04;
    letter-spacing: -0.02em;
  }

  .dt__intro {
    margin: 0;
    max-width: 38ch;
    justify-self: end;
    padding-bottom: 0.35em; /* allinea otticamente alla baseline del titolo */
    font-family: var(--font-body--family, system-ui);
    font-size: 1rem;
    line-height: 1.6;
    color: rgb(var(--dt-fg-rgb) / 0.78);
  }

  .dt__stitch {
    display: block;
    width: 100%;
    height: 2px;
    margin-block: clamp(32px, 5vw, 56px);
    color: rgb(var(--dt-fg-rgb) / 0.4);
  }
  .dt__stitch svg { width: 100%; height: 100%; display: block; }

  .dt__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(16px, 2vw, 28px);
  }

  .dt__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: clamp(22px, 2.4vw, 32px);
    background: rgb(var(--dt-fg-rgb) / 0.025);
    border: 1px solid rgb(var(--dt-fg-rgb) / 0.12);
    border-radius: 2px;
    transition: border-color 0.4s ease, transform 0.4s ease, background 0.4s ease;
  }
  .dt__card:hover {
    border-color: rgb(var(--dt-gold-rgb) / 0.6);
    background: rgb(var(--dt-fg-rgb) / 0.04);
    transform: translateY(-3px);
  }

  .dt__card-brand {
    margin: 0 0 0.7rem;
    font-family: var(--font-body--family, system-ui);
    font-size: 0.64rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgb(var(--dt-fg-rgb) / 0.5);
  }

  .dt__card-tag {
    align-self: flex-start;
    margin-bottom: 0.7rem;
    padding: 0.2em 0.7em;
    font-family: var(--font-body--family, system-ui);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(var(--dt-gold-rgb));
    border: 1px solid rgb(var(--dt-gold-rgb) / 0.5);
    border-radius: 999px;
  }

  .dt__card-name {
    margin: 0 0 1rem;
    font-family: 'Fraunces', var(--font-heading--family, serif);
    font-weight: 400;
    font-variation-settings: 'opsz' 40;
    font-size: clamp(1.2rem, 1.6vw, 1.5rem);
    line-height: 1.12;
    letter-spacing: -0.01em;
  }

  .dt__card-line {
    margin: 0 0 0.55rem;
    font-family: var(--font-body--family, system-ui);
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgb(var(--dt-fg-rgb) / 0.82);
  }

  .dt__card-phone {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
  }
  .dt__card-phone:hover { border-bottom-color: rgb(var(--dt-gold-rgb)); }

  .dt__card-hours {
    color: rgb(var(--dt-fg-rgb) / 0.6);
    font-size: 0.86rem;
  }

  .dt__card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    margin-top: auto;
    padding-top: 1.2rem;
    font-family: var(--font-body--family, system-ui);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(var(--dt-fg-rgb));
    text-decoration: none;
  }
  .dt__card-cta svg { color: rgb(var(--dt-gold-rgb)); transition: transform 0.3s ease; }
  .dt__card-cta:hover svg { transform: translateY(-2px); }
  .dt__card-cta span {
    border-bottom: 1px solid rgb(var(--dt-fg-rgb) / 0.25);
    padding-bottom: 2px;
    transition: border-color 0.3s ease;
  }
  .dt__card-cta:hover span { border-bottom-color: rgb(var(--dt-gold-rgb)); }

  /* Reveal */
  [data-dt-reveal] {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-dt-reveal].is-in { opacity: 1; transform: none; }

  @media screen and (max-width: 990px) {
    .dt__head { grid-template-columns: 1fr; align-items: start; }
    .dt__intro { justify-self: start; padding-bottom: 0; margin-top: 1.1rem; }
    .dt__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media screen and (max-width: 560px) {
    .dt__grid { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-dt-reveal] { opacity: 1 !important; transform: none !important; transition: none; }
    .dt__card, .dt__card:hover { transform: none; }
  }
{% endstylesheet %}

<script>
  (function () {
    var root = document.querySelector('#DoveTrovarci-{{ section.id }}');
    if (!root) return;
    var items = root.querySelectorAll('[data-dt-reveal]');
    if (!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      items.forEach(function (el) { el.classList.add('is-in'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry, i) {
        if (entry.isIntersecting) {
          var el = entry.target;
          setTimeout(function () { el.classList.add('is-in'); }, (el.dataset.dtDelay || 0) * 1);
          io.unobserve(el);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
    items.forEach(function (el, i) {
      el.dataset.dtDelay = Math.min(i, 6) * 70;
      io.observe(el);
    });
  })();
</script>

