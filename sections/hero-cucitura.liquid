{% liquid
  assign line_top = section.settings.line_top | default: 'SARTORIA'
  assign line_bottom = section.settings.line_bottom | default: 'CONDOTTI'
  assign sr_text = line_top | append: ' ' | append: line_bottom
  assign eyebrow_text = section.settings.eyebrow
  assign placeholder_key = section.settings.placeholder | default: 'hero-apparel-1'
%}

<link
  rel="preconnect"
  href="https://fonts.googleapis.com"
  crossorigin
>
<link
  rel="preconnect"
  href="https://fonts.gstatic.com"
  crossorigin
>
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400&display=swap"
>

<div
  id="HeroCucitura-{{ section.id }}"
  class="hero-cucitura color-{{ section.settings.color_scheme }}"
  data-hc-root
  style="
    --hc-bg: {{ section.settings.bg_color.red }} {{ section.settings.bg_color.green }} {{ section.settings.bg_color.blue }};
    --hc-fg: {{ section.settings.fg_color.red }} {{ section.settings.fg_color.green }} {{ section.settings.fg_color.blue }};
    --hc-swan: {{ section.settings.swan_color.red }} {{ section.settings.swan_color.green }} {{ section.settings.swan_color.blue }};
    --hc-swan-url: url('{{ 'cigno.svg' | asset_url }}');
    --hc-display-size: {{ section.settings.display_size }}vw;
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <div class="hero-cucitura__viewport">
    <div class="hero-cucitura__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 3840
          | image_tag:
            width: section.settings.image.width,
            widths: '832, 1200, 1600, 1920, 2560, 3840',
            height: section.settings.image.height,
            alt: section.settings.image.alt,
            class: 'hero-cucitura__image',
            sizes: '100vw',
            fetchpriority: 'high'
        }}
      {%- else -%}
        <img
          src="{{ 'hero169.png' | asset_url }}"
          alt=""
          class="hero-cucitura__image"
          fetchpriority="high"
          loading="eager"
        >
      {%- endif -%}
    </div>

    <h1 class="hero-cucitura__sr">{{ sr_text }}</h1>

    <div class="hero-cucitura__panel hero-cucitura__panel--top" data-hc-top aria-hidden="true">
      {%- if eyebrow_text != blank -%}
        <p class="hero-cucitura__eyebrow">{{ eyebrow_text }}</p>
      {%- endif -%}
      <span class="hero-cucitura__line">{{ line_top }}</span>
      <span class="hero-cucitura__swan hero-cucitura__swan--top" aria-hidden="true"></span>
    </div>

    <div class="hero-cucitura__panel hero-cucitura__panel--bot" data-hc-bot aria-hidden="true">
      <span class="hero-cucitura__line">{{ line_bottom }}</span>
      <span class="hero-cucitura__swan hero-cucitura__swan--bot" aria-hidden="true"></span>
    </div>

    <div class="hero-cucitura__stitch" data-hc-stitch aria-hidden="true">
      <svg viewBox="0 0 1000 2" preserveAspectRatio="none">
        <line
          x1="0" y1="1" x2="1000" y2="1"
          stroke="rgb(var(--hc-fg))"
          stroke-width="1.4"
          stroke-dasharray="7 5"
          vector-effect="non-scaling-stroke"
        />
      </svg>
    </div>
  </div>
</div>

<script src="{{ 'gsap.min.js' | asset_url }}" defer></script>
<script src="{{ 'ScrollTrigger.min.js' | asset_url }}" defer></script>
<script src="{{ 'hero-cucitura.js' | asset_url }}" defer></script>

{% stylesheet %}
  .hero-cucitura {
    --hc-bg-rgb: var(--hc-bg, 244 239 230);
    --hc-fg-rgb: var(--hc-fg, 14 14 12);
    --hc-display-size: 18vw;
    --hc-letter-spacing: -0.03em;
    position: relative;
    color: rgb(var(--hc-fg-rgb));
  }

  .hero-cucitura__viewport {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    isolation: isolate;
    background: #000;
  }

  .hero-cucitura__media {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero-cucitura__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-cucitura__panel {
    position: absolute;
    left: 0;
    right: 0;
    height: 50%;
    z-index: 3;
    background: rgb(var(--hc-bg-rgb));
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    will-change: transform;
  }

  .hero-cucitura__panel--top {
    top: 0;
    justify-content: space-between;
    padding-block-start: clamp(24px, 5vh, 56px);
    padding-block-end: 0;
  }

  .hero-cucitura__panel--bot {
    bottom: 0;
    justify-content: flex-start;
    padding-block-start: 0;
  }

  .hero-cucitura__eyebrow {
    margin: 0;
    font-family: var(--font-body--family, system-ui);
    font-size: 0.72rem;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: rgb(var(--hc-fg-rgb) / 0.78);
    white-space: nowrap;
  }

  .hero-cucitura__line {
    font-family: 'Fraunces', var(--font-heading--family, serif);
    font-weight: 300;
    font-variation-settings: 'opsz' 144;
    font-size: var(--hc-display-size);
    line-height: 1;
    letter-spacing: var(--hc-letter-spacing);
    text-transform: uppercase;
    text-align: center;
    white-space: nowrap;
    color: rgb(var(--hc-fg-rgb));
    display: block;
  }

  .hero-cucitura__panel--top .hero-cucitura__line {
    margin-block-end: 0.08em;
  }

  .hero-cucitura__panel--bot .hero-cucitura__line {
    margin-block-start: 0.04em;
  }

  .hero-cucitura__stitch {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 3;
    pointer-events: none;
    transform: translateY(-50%);
    color: rgb(var(--hc-fg-rgb) / 0.55);
    will-change: opacity, transform;
  }

  .hero-cucitura__swan {
    position: absolute;
    left: 50%;
    width: min(140vh, 140vw);
    aspect-ratio: 1 / 1;
    pointer-events: none;
    user-select: none;
    opacity: 0.55;
    z-index: 2;
    background-color: rgb(var(--hc-swan, 212 162 76));
    -webkit-mask-image: var(--hc-swan-url);
    mask-image: var(--hc-swan-url);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
  }

  .hero-cucitura__panel--top .hero-cucitura__swan {
    bottom: 0;
    transform: translate(-50%, 50%);
  }

  .hero-cucitura__panel--bot .hero-cucitura__swan {
    top: 0;
    transform: translate(-50%, -50%);
  }

  .hero-cucitura__stitch svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-cucitura__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media screen and (max-width: 749px) {
    .hero-cucitura {
      --hc-display-size: 19vw;
    }
    .hero-cucitura__eyebrow {
      font-size: 0.66rem;
      letter-spacing: 0.36em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-cucitura__panel--top {
      transform: translateY(-100%) !important;
    }
    .hero-cucitura__panel--bot {
      transform: translateY(100%) !important;
    }
    .hero-cucitura__stitch {
      opacity: 0 !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Cucitura",
  "tag": "section",
  "class": "hero-cucitura-wrapper section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Testo"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Napoli · Atelier · Dal 1954"
    },
    {
      "type": "text",
      "id": "line_top",
      "label": "Riga superiore",
      "default": "SARTORIA"
    },
    {
      "type": "text",
      "id": "line_bottom",
      "label": "Riga inferiore",
      "default": "CONDOTTI"
    },
    {
      "type": "range",
      "id": "display_size",
      "label": "Dimensione testo (vw)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 18,
      "unit": "vw"
    },
    {
      "type": "header",
      "content": "Immagine"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Immagine atelier"
    },
    {
      "type": "select",
      "id": "placeholder",
      "label": "Placeholder se manca immagine",
      "options": [
        { "value": "hero-apparel-1", "label": "Apparel 1" },
        { "value": "hero-apparel-2", "label": "Apparel 2" },
        { "value": "lifestyle-1", "label": "Lifestyle 1" },
        { "value": "detail-1", "label": "Detail 1" }
      ],
      "default": "hero-apparel-1"
    },
    {
      "type": "header",
      "content": "Cromia"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Sfondo",
      "default": "#14213D"
    },
    {
      "type": "color",
      "id": "fg_color",
      "label": "Testo / cucitura",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "swan_color",
      "label": "Cigno (filigrana)",
      "default": "#D4A24C"
    }
  ],
  "presets": [
    {
      "name": "Hero Cucitura",
      "category": "Banners",
      "settings": {
        "eyebrow": "Napoli · Atelier · Dal 1954",
        "line_top": "SARTORIA",
        "line_bottom": "CONDOTTI"
      }
    }
  ]
}
{% endschema %}
