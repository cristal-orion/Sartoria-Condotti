{%- liquid
  assign s = section.settings
  assign hero_title = s.hero_title | default: 'Condotti & Co'
  assign eyebrow = s.eyebrow | default: 'Napoli · Dal 1954'
-%}

<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&display=swap">
{{ 'brand-page.css' | asset_url | stylesheet_tag }}

<section class="bp" data-bp-root>
  <!-- HERO (titolo + striscia foto) -->
  <header class="bp__hero-strip">
    <div class="bp__wrap bp__hero-strip__head">
      <p class="bp__eyebrow" data-reveal>{{ eyebrow }}</p>
      <h1 class="bp__display bp__hero-strip__title" data-reveal>{{ hero_title }}</h1>
      <p class="bp__hero-strip__sub" data-reveal>{{ s.hero_sub | default: 'Il guardaroba di tutti i giorni con la mano della sartoria. Casual contemporaneo, mai casuale.' }}</p>
    </div>
    {%- if s.gallery_images != blank -%}
      <div class="bp-gallery__track" data-reveal role="list">
        {%- assign gallery_files = s.gallery_images | split: ',' -%}
        {%- for raw in gallery_files -%}{%- assign file = raw | strip -%}{%- if file != blank -%}
          <figure class="bp-gallery__item" role="listitem"><img src="{{ file | asset_url }}" width="1100" height="1650" loading="lazy" alt="{{ hero_title }}"></figure>
        {%- endif -%}{%- endfor -%}
      </div>
      {%- if s.gallery_hint != blank -%}<p class="bp-gallery__hint" data-reveal>{{ s.gallery_hint }}</p>{%- endif -%}
    {%- endif -%}
  </header>

  <!-- INTRO -->
  <div class="bp__section bp__wrap">
    <div class="bp__intro">
      {%- if s.intro_eyebrow != blank -%}<p class="bp__eyebrow" data-reveal>{{ s.intro_eyebrow }}</p>{%- endif -%}
      <h2 class="bp__h2" data-reveal>{{ s.intro_heading | default: 'La stessa cura del su misura, in chiave quotidiana.' }}</h2>
      <p class="bp__lead bp__body" data-reveal>{{ s.intro_body | default: 'Capi pensati per essere vissuti: tessuti italiani, vestibilità pulite, dettagli che durano. La sartoria che esce dall’atelier e ti segue ovunque.' }}</p>
    </div>
  </div>

  <span class="bp__stitch bp__wrap" aria-hidden="true">
    <svg viewBox="0 0 1000 2" preserveAspectRatio="none"><line x1="0" y1="1" x2="1000" y2="1" stroke="currentColor" stroke-width="1.4" stroke-dasharray="7 5" vector-effect="non-scaling-stroke"/></svg>
  </span>

  <!-- VALORI -->
  <div class="bp__section bp__wrap">
    <div class="bp__section-head">
      {%- if s.values_eyebrow != blank -%}<p class="bp__eyebrow" data-reveal>{{ s.values_eyebrow }}</p>{%- endif -%}
      <h2 class="bp__h2" data-reveal>{{ s.values_heading | default: 'Essenziale, ma mai banale.' }}</h2>
    </div>
    <div class="bp__steps">
      <div class="bp__step" data-reveal>
        <span class="bp__num">01</span>
        <h3>Tessuti italiani</h3>
        <p class="bp__body">Cotoni, lini e jersey selezionati per durare e invecchiare bene. La qualità si sente alla prima volta che lo indossi.</p>
      </div>
      <div class="bp__step" data-reveal>
        <span class="bp__num">02</span>
        <h3>Vestibilità studiate</h3>
        <p class="bp__body">Linee pulite, comode senza essere sciatte. La proporzione giusta tra agio e forma.</p>
      </div>
      <div class="bp__step" data-reveal>
        <span class="bp__num">03</span>
        <h3>Dettagli sartoriali</h3>
        <p class="bp__body">Cuciture, bottoni, finiture: la mano dell’atelier resta anche nel capo più semplice.</p>
      </div>
    </div>
  </div>

  <!-- SHOWCASE PRODOTTI (ink) -->
  <div class="bp bp--ink" style="background:rgb(var(--bp-ink));color:rgb(var(--bp-cream));">
    <div class="bp__section bp__wrap">
      <div class="bp__section-head">
        {%- if s.collection_eyebrow != blank -%}<p class="bp__eyebrow" data-reveal>{{ s.collection_eyebrow }}</p>{%- endif -%}
        <h2 class="bp__h2" data-reveal>{{ s.collection_heading | default: 'Da indossare ogni giorno' }}</h2>
      </div>
      {%- if s.collection != blank and s.collection.products_count > 0 -%}
        <div class="bp__products" data-reveal>
          {%- for product in s.collection.products limit: s.products_limit -%}
            <a class="bp__product" href="{{ product.url }}">
              <div class="bp__product-media">
                {%- if product.featured_image -%}
                  {{ product.featured_image | image_url: width: 800 | image_tag: widths: '300,500,800', sizes: '(max-width:640px) 50vw, 25vw', loading: 'lazy' }}
                {%- endif -%}
              </div>
              <p class="bp__product-title">{{ product.title }}</p>
              <p class="bp__product-price">{{ product.price | money }}</p>
            </a>
          {%- endfor -%}
        </div>
        <div data-reveal style="margin-top:clamp(36px,4vw,56px);">
          <a class="bp__btn" href="{{ s.collection.url }}">Vedi tutta la collezione</a>
        </div>
      {%- else -%}
        <p class="bp__body" data-reveal style="max-width:46ch;">La collezione casual è in arrivo. Collega una collezione a questa sezione dal personalizzatore per mostrare qui i capi.</p>
      {%- endif -%}
    </div>
  </div>

  <!-- CTA -->
  <div class="bp__section bp__wrap">
    <div class="bp__cta">
      {%- if s.cta_eyebrow != blank -%}<p class="bp__eyebrow" data-reveal>{{ s.cta_eyebrow }}</p>{%- endif -%}
      <h2 class="bp__display" data-reveal>{{ s.cta_heading | default: 'La sartoria, ogni giorno.' }}</h2>
      <a class="bp__btn" href="{{ s.cta_link | default: '/collections/condotti-co' }}" data-reveal>{{ s.cta_label | default: 'Scopri i capi' }}</a>
    </div>
  </div>
</section>

<script src="{{ 'gsap.min.js' | asset_url }}" defer></script>
<script src="{{ 'ScrollTrigger.min.js' | asset_url }}" defer></script>
<script src="{{ 'brand-page.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Brand · Condotti & Co",
  "tag": "section",
  "class": "brand-page-section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "image_picker", "id": "hero_image", "label": "Immagine hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Napoli · Dal 1954" },
    { "type": "text", "id": "hero_title", "label": "Titolo", "default": "Condotti & Co" },
    { "type": "textarea", "id": "hero_sub", "label": "Sottotitolo" },
    { "type": "header", "content": "Intro" },
    { "type": "text", "id": "intro_eyebrow", "label": "Eyebrow intro" },
    { "type": "text", "id": "intro_heading", "label": "Titolo intro" },
    { "type": "textarea", "id": "intro_body", "label": "Testo intro" },
    { "type": "header", "content": "Hero · striscia foto" },
    { "type": "textarea", "id": "gallery_images", "label": "Foto hero (file in assets/, separati da virgola)", "info": "Lascia vuoto per nascondere la striscia.", "default": "condottico-01.jpg, condottico-02.jpg, condottico-03.jpg, condottico-04.jpg, condottico-05.jpg, condottico-06.jpg, condottico-07.jpg, condottico-08.jpg, condottico-09.jpg, condottico-10.jpg, condottico-11.jpg" },
    { "type": "text", "id": "gallery_hint", "label": "Nota striscia", "default": "‹ scorri ›" },
    { "type": "header", "content": "Valori" },
    { "type": "text", "id": "values_eyebrow", "label": "Eyebrow valori" },
    { "type": "text", "id": "values_heading", "label": "Titolo valori" },
    { "type": "header", "content": "Showcase prodotti" },
    { "type": "text", "id": "collection_eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "collection_heading", "label": "Titolo" },
    { "type": "collection", "id": "collection", "label": "Collezione" },
    { "type": "range", "id": "products_limit", "label": "Prodotti mostrati", "min": 4, "max": 12, "step": 4, "default": 8 },
    { "type": "header", "content": "CTA finale" },
    { "type": "text", "id": "cta_eyebrow", "label": "Eyebrow CTA" },
    { "type": "text", "id": "cta_heading", "label": "Titolo CTA" },
    { "type": "text", "id": "cta_label", "label": "Etichetta bottone", "default": "Scopri i capi" },
    { "type": "url", "id": "cta_link", "label": "Link bottone" }
  ],
  "presets": [{ "name": "Brand · Condotti & Co" }]
}
{% endschema %}
