{
  "type": "header",
  "name": "Header",
  "sections": {
    "header_section": {
      "type": "header",
      "blocks": {
        "header-logo": {
          "type": "_header-logo",
          "static": true,
          "settings": {
            "hide_logo_on_home_page": true,
            "custom_height": 80,
            "custom_height_mobile": 50,
            "padding-block-start": 24,
            "padding-block-end": 24,
            "padding-inline-start": 10,
            "padding-inline-end": 10
          },
          "blocks": {}
        },
        "header-menu": {
          "type": "_header-menu",
          "static": true,
          "settings": {
            "menu": "main-menu",
            "menu_style": "text",
            "featured_products_aspect_ratio": "4 / 5",
            "featured_collections_aspect_ratio": "16 / 9",
            "image_border_radius": 0,
            "product_title_case": "uppercase",
            "collection_title_case": "default",
            "color_scheme": "scheme-1",
            "menu_font_style": "regular",
            "type_font_primary_link": "subheading",
            "type_font_primary_size": "var(--font-size--body-sm)",
            "type_case_primary_link": "uppercase",
            "type_font_secondary_link": "subheading",
            "type_case_secondary_link": "uppercase",
            "type_font_tertiary_link": "primary",
            "type_case_tertiary_link": "uppercase",
            "navigation_bar": false,
            "color_scheme_navigation_bar": "",
            "drawer_accordion": false,
            "drawer_accordion_expand_first": false,
            "drawer_dividers": false
          },
          "blocks": {}
        }
      },
      "settings": {
        "logo_position": "center",
        "menu_position": "left",
        "menu_row": "top",
        "show_search": true,
        "search_position": "left",
        "search_row": "top",
        "show_country": true,
        "country_selector_style": false,
        "show_language": false,
        "localization_font": "subheading",
        "localization_font_size": "0.75rem",
        "localization_position": "right",
        "localization_row": "top",
        "section_width": "full-width",
        "section_height": "standard",
        "enable_sticky_header": "scroll-up",
        "divider_width": 0,
        "divider_size": "page-width",
        "border_width": 0.5,
        "color_scheme_top": "scheme-1",
        "color_scheme_bottom": "",
        "color_scheme_transparent": "scheme-6",
        "enable_transparent_header_home": true,
        "home_color_scheme": "default",
        "enable_transparent_header_product": true,
        "product_color_scheme": "default",
        "enable_transparent_header_collection": true,
        "collection_color_scheme": "default"
      }
    },
    "custom_liquid_KJRnga": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<div class=\"appointo-custom-btn\" data-appointo-product-handle=\"su-misura\" type=\"embed\"></div>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    }
