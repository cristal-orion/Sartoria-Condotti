{%- comment -%}
  Collection · Sartoria Condotti — UI editoriale (cream/ink, Fraunces, 2 col portrait).
  Self-contained come le brand page: riusa il design system .bp (assets/brand-page.css)
  + carica Fraunces. NON usa la griglia nativa del tema (niente filtri) — pensata per
  un catalogo curato/lookbook. Assegnare in Admin alla collezione "sartoria-condotti".
{%- endcomment -%}

{%- assign s = section.settings -%}

<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&display=swap">
{{ 'brand-page.css' | asset_url | stylesheet_tag }}

<style>
  #cs-{{ section.id }} {
    padding-block: clamp(48px, 7vw, 110px);
  }
  #cs-{{ section.id }} .bpc__inner {
    max-width: var(--bp-maxw);
    margin-inline: auto;
    padding-inline: var(--bp-pad-x);
  }
  #cs-{{ section.id }} .bpc__head {
    display: grid;
    gap: clamp(14px, 1.6vw, 22px);
    max-width: 62ch;
    margin-bottom: clamp(38px, 5vw, 72px);
  }
  #cs-{{ section.id }} .bpc__title {
    font-size: clamp(2.6rem, 7vw, 5.5rem);
  }
  #cs-{{ section.id }} .bpc__count {
    font-size: 0.72rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgb(var(--bp-fg) / 0.66);
  }
  #cs-{{ section.id }} .bpc__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: clamp(20px, 3vw, 56px);
    row-gap: clamp(44px, 5vw, 88px);
  }
  #cs-{{ section.id }} .bpc__card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  #cs-{{ section.id }} .bpc__media {
    position: relative;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    background: rgb(var(--bp-fg) / 0.04);
    margin-bottom: clamp(14px, 1.4vw, 22px);
  }
  #cs-{{ section.id }} .bpc__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.1s cubic-bezier(0.19, 1, 0.22, 1), opacity 0.6s ease;
  }
  #cs-{{ section.id }} .bpc__media .bpc__img--alt {
    opacity: 0;
  }
  #cs-{{ section.id }} .bpc__card:hover .bpc__media img,
  #cs-{{ section.id }} .bpc__card:focus-visible .bpc__media img {
    transform: scale(1.04);
  }
  #cs-{{ section.id }} .bpc__card:hover .bpc__media .bpc__img--alt,
  #cs-{{ section.id }} .bpc__card:focus-visible .bpc__media .bpc__img--alt {
    opacity: 1;
  }
  #cs-{{ section.id }} .bpc__card:focus-visible {
    outline: 2px solid rgb(var(--bp-gold));
    outline-offset: 4px;
  }
  #cs-{{ section.id }} .bpc__name {
    font-family: 'Fraunces', var(--font-heading--family, serif);
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: clamp(1.15rem, 1.6vw, 1.45rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 6px;
  }
  #cs-{{ section.id }} .bpc__price {
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    color: rgb(var(--bp-fg) / 0.7);
    margin: 0;
  }
  #cs-{{ section.id }} .bpc__price del {
    color: rgb(var(--bp-fg) / 0.4);
    margin-right: 8px;
  }
  #cs-{{ section.id }} .bpc__empty {
    padding-block: clamp(60px, 10vw, 140px);
    text-align: center;
  }
  #cs-{{ section.id }} .bpc__pager {
    display: flex;
    justify-content: center;
    gap: 18px;
    margin-top: clamp(56px, 6vw, 96px);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
  }
  #cs-{{ section.id }} .bpc__pager a,
  #cs-{{ section.id }} .bpc__pager span {
    color: rgb(var(--bp-fg) / 0.66);
    text-decoration: none;
  }
  #cs-{{ section.id }} .bpc__pager a:hover { color: rgb(var(--bp-fg)); }
  #cs-{{ section.id }} .bpc__pager a:focus-visible {
    outline: 2px solid rgb(var(--bp-gold));
    outline-offset: 3px;
    color: rgb(var(--bp-fg));
  }
  #cs-{{ section.id }} .bpc__pager .bpc__pager--current {
    color: rgb(var(--bp-fg));
    border-bottom: 1px solid currentColor;
  }
  /* reveal */
  #cs-{{ section.id }} [data-cs-reveal] {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
  }
  #cs-{{ section.id }} [data-cs-reveal].is-in {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    #cs-{{ section.id }} [data-cs-reveal] { opacity: 1; transform: none; transition: none; }
    #cs-{{ section.id }} .bpc__media img { transition: none; }
  }
  @media (max-width: 749px) {
    #cs-{{ section.id }} .bpc__grid { grid-template-columns: 1fr; }
  }
</style>

<section
  id="cs-{{ section.id }}"
  class="bp{% if s.color_variant == 'ink' %} bp--ink{% endif %}"
  style="padding-block-start: {{ s['padding-block-start'] }}px; padding-block-end: {{ s['padding-block-end'] }}px;"
>
  <div class="bpc__inner">
    <header class="bpc__head">
      {%- if s.eyebrow != blank -%}
        <p class="bp__eyebrow" data-cs-reveal>{{ s.eyebrow }}</p>
      {%- endif -%}
      <h1 class="bp__display bpc__title" data-cs-reveal>
        {{ s.heading | default: collection.title }}
      </h1>
      {%- if s.intro != blank -%}
        <p class="bp__body" data-cs-reveal>{{ s.intro }}</p>
      {%- elsif collection.description != blank and s.show_collection_description -%}
        <div class="bp__body" data-cs-reveal>{{ collection.description }}</div>
      {%- endif -%}
      <p class="bpc__count" data-cs-reveal>{{ collection.products_count }} {% if collection.products_count == 1 %}capo{% else %}capi{% endif %}</p>
    </header>

    {%- paginate collection.products by s.products_per_page -%}
      {%- if collection.products.size > 0 -%}
        <div class="bpc__grid">
          {%- for product in collection.products -%}
            <a class="bpc__card" href="{{ product.url }}" data-cs-reveal>
              <div class="bpc__media">
                {%- if product.featured_media -%}
                  {{ product.featured_media | image_url: width: 900 | image_tag: widths: '400,600,900', sizes: '(max-width:749px) 100vw, 45vw', loading: 'lazy', alt: product.title }}
                {%- endif -%}
                {%- if product.media[1] -%}
                  {{ product.media[1] | image_url: width: 900 | image_tag: widths: '400,600,900', sizes: '(max-width:749px) 100vw, 45vw', loading: 'lazy', alt: '', class: 'bpc__img--alt' }}
                {%- endif -%}
              </div>
              <h2 class="bpc__name">{{ product.title }}</h2>
              <p class="bpc__price">
                {%- if product.compare_at_price > product.price -%}
                  <del>{{ product.compare_at_price | money }}</del>
                {%- endif -%}
                {%- if product.price_varies -%}
                  da {{ product.price_min | money }}
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </p>
            </a>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="bpc__pager" aria-label="Paginazione collezione">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" rel="prev">←</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}
                <span class="{% if part.title == paginate.current_page %}bpc__pager--current{% endif %}">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" rel="next">→</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="bpc__empty">
          <p class="bp__lead">La collezione è in arrivo.</p>
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('cs-{{ section.id }}');
    if (!root) return;
    var items = root.querySelectorAll('[data-cs-reveal]');
    if (!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      items.forEach(function (el) { el.classList.add('is-in'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
      });
    }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
    items.forEach(function (el) { io.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "Collezione · Sartoria",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Testata" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Sartoria Condotti" },
    { "type": "text", "id": "heading", "label": "Titolo", "info": "Se vuoto usa il nome della collezione." },
    { "type": "textarea", "id": "intro", "label": "Introduzione", "default": "Capi su misura tagliati uno a uno. Ogni pezzo nasce dalla stessa cura dell’atelier napoletano, dal 1954." },
    { "type": "checkbox", "id": "show_collection_description", "label": "Usa la descrizione collezione se l'introduzione è vuota", "default": false },
    { "type": "header", "content": "Griglia" },
    { "type": "range", "id": "products_per_page", "label": "Prodotti per pagina", "min": 6, "max": 36, "step": 2, "default": 12 },
    {
      "type": "select", "id": "color_variant", "label": "Sfondo", "default": "cream",
      "options": [
        { "value": "cream", "label": "Cream" },
        { "value": "ink", "label": "Ink (scuro)" }
      ]
    },
    { "type": "header", "content": "Spaziatura" },
    { "type": "range", "id": "padding-block-start", "label": "Padding sopra", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding-block-end", "label": "Padding sotto", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 96 }
  ],
  "presets": [
    { "name": "Collezione · Sartoria" }
  ]
}
{% endschema %}
